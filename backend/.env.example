# Server
SERVER_PORT=8080
SERVER_ENV=development
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=rmm
DB_PASSWORD=rmm_password
DB_NAME=rmm_platform
DB_SSLMODE=disable
DB_MAX_OPEN=25
DB_MAX_IDLE=5
DB_MAX_LIFETIME=5m

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-me-in-production-use-a-strong-256-bit-key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Agent
AGENT_HEARTBEAT_INTERVAL=30s
AGENT_OFFLINE_THRESHOLD=2m
AGENT_METRICS_INTERVAL=30s

# RustDesk
RUSTDESK_API_ENDPOINT=
RUSTDESK_API_TOKEN=
